# ── API server :: 0G Storage (Evidence Locker uploads)
# Put these in EITHER the repo-root `.env` (recommended) OR `server/.env`.
# The dev API merges both files: blank `KEY=` entries never wipe a value from the other file;
# if both define a nonempty value for the same key, repo-root `.env` wins.
# Get test OG tokens from https://faucet.0g.ai for the SAME wallet below.
OG_STORAGE_PRIVATE_KEY=
OG_STORAGE_RPC_URL=https://evmrpc-testnet.0g.ai
OG_STORAGE_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai

# Base URL opened in-app ("Verify on Storage Scan"). Searchpaste root hash (cid) there.
OG_STORAGE_VERIFY_BASE=https://storagescan.0g.ai

# Optional: deep link template; must include literal {rootHash} if set
# OG_STORAGE_GATEWAY_TEMPLATE=https://storagescan.0g.ai/file/{rootHash}

# Local API port (optional)
AEGIS_API_PORT=8787

# Vercel: add the OG_* vars (especially OG_STORAGE_PRIVATE_KEY) in Project → Settings →
# Environment Variables. Production uploads use api/ipfs/upload (serverless, ~4–5 MiB limit on Hobby).

# ── KeeperHub :: SOS Direct Execution (https://docs.keeperhub.com/api/direct-execution)
# Org API key kh_*. Transfers YOUR KeeperHub-managed wallet balance — not MetaMask signer funds.
KEEPERHUB_API_KEY=
# Network slug KeeperHub recognises (must match Dashboard /chains — e.g. sepolia).
KEEPERHUB_SOS_NETWORK=sepolia
# Amount in human-readable native units sent per SOS (configure for funded testnet treasury).
KEEPERHUB_SOS_AMOUNT=0.01
# Optional: echo chain id into UI response if status payloads omit chainId.
# KEEPERHUB_SOS_CHAIN_ID=11155111
# Optional override (default https://app.keeperhub.com/api )
# KEEPERHUB_API_BASE=https://app.keeperhub.com/api
# KEEPERHUB_GAS_MULTIPLIER=1.2

# If the web app is not same-origin as the API, set this to the API origin (optional)
# VITE_API_BASE=http://localhost:8787
# Prefer KeeperHub SOS when API health reports keeperHubSosConfigured=true
# VITE_SOS_USE_KEEPERHUB=true

# ── Marketing / explorer links (browser bundle; no secrets)
# Replace after deploy (no trailing slashes on origins)
# VITE_LIVE_APP_URL=https://your-aegis-app.vercel.app
# VITE_LANDING_URL=https://your-aegis-landing.vercel.app
# VITE_AGENT_DASHBOARD_URL=https://your-aegis-app.vercel.app/dashboard
# VITE_DONATION_URL=https://your-aegis-app.vercel.app/donate

# Contracts & treasury — use checksummed mainnet-or-your-chain addresses when ready
# VITE_TOKEN_CONTRACT=0x...
# VITE_AGENT_CONTRACT=0x...
# VITE_TREASURY_ADDRESS=0x...
