# Pinata (server-side only; never expose in the browser bundle)
PINATA_JWT=

# Optional dedicated Pinata gateway domain (from Pinata dashboard), e.g.:
# PINATA_GATEWAY=fun-llama-300.mypinata.cloud
PINATA_GATEWAY=

# Local API port (optional)
AEGIS_API_PORT=8787

# Public gateway URL fallback for IPFS links (optional, used if PINATA_GATEWAY is empty)
IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs

# If the web app is not same-origin as the API, set this to the API origin (optional)
# VITE_API_BASE=http://localhost:8787

# ── Marketing / explorer links (browser bundle; no secrets)
# Replace after deploy (no trailing slashes on origins)
# VITE_LIVE_APP_URL=https://your-aegis-app.vercel.app
# VITE_LANDING_URL=https://your-aegis-landing.vercel.app
# VITE_AGENT_DASHBOARD_URL=https://your-aegis-app.vercel.app/dashboard
# VITE_DONATION_URL=https://your-aegis-app.vercel.app/donate

# Contracts & treasury — use checksummed mainnet-or-your-chain addresses when ready
# VITE_TOKEN_CONTRACT=0x...
# VITE_AGENT_CONTRACT=0x...
# VITE_TREASURY_ADDRESS=0x...
